Package: rayforestr
Type: Package
Title: RayCloudTools and TreeTools Pipelines for Forestry in R
Version: 0.0.8
Authors@R: c(
    person(given = "Muhammad", family = "Ali",
           email = "your_email@example.com",
           role = c("aut", "cre")),
    person(given = "OpenAI", family = "Assistant", role = c("ctb"))
